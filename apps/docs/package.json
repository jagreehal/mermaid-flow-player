{
  "name": "docs",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "copy-player": "node scripts/copy-player.mjs",
    "link-player": "node scripts/link-player.mjs",
    "dev": "pnpm run copy-player && astro dev",
    "dev:root": "BASE=/ pnpm run copy-player && BASE=/ astro dev",
    "build": "pnpm run copy-player && astro check && astro build",
    "type-check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "test:e2e": "playwright test",
    "test:e2e:all": "E2E_ALL_BROWSERS=1 playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chrome": "playwright test --project=chrome"
  },
  "dependencies": {
    "astro": "^6.0.6",
    "@astrojs/starlight": "^0.37.6",
    "@astrojs/check": "^0.9.6",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "starlight-theme-next": "^0.3.3",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/geist-mono": "^5.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "executable-stories-formatters": "^0.6.1",
    "executable-stories-playwright": "^7.0.1",
    "typescript": "^5.9.3",
    "tw-animate-css": "^1.4.0"
  }
}
