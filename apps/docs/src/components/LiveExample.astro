---
interface Props {
  diagram: string;
  width?: string;
  height?: string;
}

const { diagram, width = '100%', height = 'auto' } = Astro.props;
---

<div class="live-example">
  <div class="mermaid" style={`width: ${width}; height: ${height};`}>
    {diagram}
  </div>
</div>

<style>
  .live-example {
    border: 1px solid var(--sl-color-gray-5, #e0e0e0);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    background: var(--sl-color-gray-7, #fafafa);
  }

  .live-example .mermaid {
    background: var(--sl-color-gray-7, white);
    padding: 1rem;
    border-radius: 4px;
  }
</style>
