---
interface Props {
  diagram: string;
  width?: string;
  height?: string;
  label?: string;
}

const { diagram, width = '100%', height = 'auto', label = 'live example' } = Astro.props;
---

<figure class="live-example">
  <figcaption class="live-example__meta">
    <span class="live-example__coord">live</span>
    <span class="live-example__label">{label}</span>
  </figcaption>
  <div class="live-example__stage">
    <div class="mermaid" style={`width: ${width}; height: ${height};`}>
      {diagram}
    </div>
  </div>
</figure>

<style>
  .live-example {
    margin: var(--space-lg) 0;
    padding: 0;
    display: grid;
    gap: var(--space-sm);
  }

  .live-example__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .live-example__coord {
    color: var(--ink-1);
    font-weight: 600;
  }

  .live-example__label {
    color: var(--ink-3);
  }

  .live-example__stage {
    border: 1px solid var(--line-1);
    border-radius: var(--radius-md);
    background: var(--surface-1);
    padding: var(--space-md);
  }

  .live-example__stage .mermaid {
    background: transparent;
  }
</style>
