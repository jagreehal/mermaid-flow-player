# Flow Player asset source: local (symlink) or CDN
# - local: use build from mermaid-flow-player-src (run: pnpm link-player)
# - cdn:   use https://cdn.jsdelivr.net/npm/mermaid-flow-player (default)
# Set the base URL for player scripts (no trailing slash):
#   Local:  /local-dist
#   CDN:    https://cdn.jsdelivr.net/npm/mermaid-flow-player
# Leave empty for default: /local-dist in dev, CDN in production.
PUBLIC_FLOW_PLAYER_BASE=
